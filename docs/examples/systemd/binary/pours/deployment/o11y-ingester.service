[Install]
WantedBy=multi-user.target

[Service]
ExecStart=/opt/ingester/bin/o11y-otel-collector --config=%Y/configs/ingester/ingester.yaml --manager-config=%Y/configs/ingester/opamp.yaml --copy-path=/var/lib/ingester/ingester.yaml
Group=o11y
KillMode=mixed
Restart=on-failure
Type=simple
User=o11y

[Unit]
After=o11y-telemetrystore-clickhouse-0-0 o11y-telemetrystore-migrator
Description=Hanzo O11y OTel Collector
Documentation=https://o11y.io/docs
Requires=o11y-telemetrystore-migrator
