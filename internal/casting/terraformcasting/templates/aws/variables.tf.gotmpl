}

variable "metastore_cpu" {
  description = "CPU units for MetaStore task"
  type        = number
  default     = 512
}

variable "metastore_memory" {
  description = "Memory (MB) for MetaStore task"
  type        = number
  default     = 1024
}

# =============================================================================
# Ingester Variables
# =============================================================================

variable "ingester_enabled" {
  description = "Enable Ingester (OpenTelemetry Collector)"
  type        = bool
  default     = {{ .Spec.Ingester.Spec.Enabled }}
}

variable "ingester_version" {
  description = "Ingester version"
  type        = string
  default     = "{{ .Spec.Ingester.Spec.Version }}"
}

variable "ingester_cpu" {
  description = "CPU units for Ingester task"
  type        = number
  default     = 1024
}

variable "ingester_memory" {
  description = "Memory (MB) for Ingester task"
  type        = number
  default     = 2048
}

# =============================================================================
# SigNoz Variables
# =============================================================================

variable "signoz_enabled" {
  description = "Enable SigNoz"
  type        = bool
  default     = {{ .Spec.Signoz.Spec.Enabled }}
}

variable "signoz_version" {
  description = "SigNoz version"
  type        = string
  default     = "{{ .Spec.Signoz.Spec.Version }}"
}

variable "signoz_cpu" {
  description = "CPU units for SigNoz task"
  type        = number
