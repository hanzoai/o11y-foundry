{{- $name := print $.Metadata.Name "-otel-collector" -}}
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ $name }}
  labels:
    app.kubernetes.io/name: {{ $name }}
    app.kubernetes.io/instance: {{ $.Metadata.Name }}
    app.kubernetes.io/component: otel-collector
    app.kubernetes.io/managed-by: kustomize
